  usedDays      Decimal             @default(0) @map("used_days") @db.Decimal(8, 2)
  notes         String?
  conflictOverride Boolean          @default(false) @map("conflict_override")
  conflictOverrideNote String?      @map("conflict_override_note")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")

  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resource      Resource?           @relation(fields: [resourceId], references: [id])
  user          User?               @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([resourceId])
  @@index([userId])
  @@index([role])
  @@index([startDate])
  @@index([endDate])
  @@index([deletedAt])
  @@map("project_resource_assignments")
}

