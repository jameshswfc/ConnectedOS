model PurchaseOrder {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poNumber             String              @unique @map("po_number")
  supplierId           String              @map("supplier_id") @db.Uuid
  supplierName         String?             @map("supplier_name")
  supplierAddress      String?             @map("supplier_address")
  supplierContactName  String?             @map("supplier_contact_name")
  supplierContactEmail String?             @map("supplier_contact_email")
  deliveryAddress      String?             @map("delivery_address")
  projectId            String?             @map("project_id") @db.Uuid
  quoteId              String?             @map("quote_id") @db.Uuid
  changeRequestId      String?             @map("change_request_id") @db.Uuid
  status               PurchaseOrderStatus @default(draft)
  requestedById        String?             @map("requested_by_id") @db.Uuid
  approvedById         String?             @map("approved_by_id") @db.Uuid
  approvedAt           DateTime?           @map("approved_at")
  orderDate            DateTime?           @map("order_date") @db.Date
  expectedDeliveryDate DateTime?           @map("expected_delivery_date") @db.Date
  receivedDate         DateTime?           @map("received_date") @db.Date
  subtotal             Decimal             @default(0) @db.Decimal(12, 2)
  vatAmount            Decimal             @default(0) @map("vat_amount") @db.Decimal(12, 2)
  totalAmount          Decimal             @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency             String              @default("GBP")
  notes                String?
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  deletedAt            DateTime?           @map("deleted_at")

  supplier             Supplier            @relation(fields: [supplierId], references: [id])
  project              Project?            @relation(fields: [projectId], references: [id])
  quote                Quote?              @relation(fields: [quoteId], references: [id])
  changeRequest        ProjectForm?        @relation("PurchaseOrderChangeRequest", fields: [changeRequestId], references: [id])
  requestedBy          User?               @relation("PurchaseOrderRequestedBy", fields: [requestedById], references: [id])
  approvedBy           User?               @relation("PurchaseOrderApprovedBy", fields: [approvedById], references: [id])
  lines                PurchaseOrderLine[]
  goodsReceipts        GoodsReceipt[]
  supplierInvoices     SupplierInvoice[]

  @@index([supplierId])
  @@index([projectId])
  @@index([quoteId])
  @@index([changeRequestId])
  @@index([status])
  @@index([expectedDeliveryDate])
  @@index([deletedAt])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId  String   @map("purchase_order_id") @db.Uuid
  productId        String?  @map("product_id") @db.Uuid
  sku              String?
  manufacturer     String?
  description      String
  quantity         Decimal  @default(1) @db.Decimal(12, 2)
  unitCost         Decimal  @default(0) @map("unit_cost") @db.Decimal(12, 2)
  totalCost        Decimal  @default(0) @map("total_cost") @db.Decimal(12, 2)
  taxRate          Decimal  @default(20) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount        Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalIncludingTax Decimal @default(0) @map("total_including_tax") @db.Decimal(12, 2)
  receivedQuantity Decimal  @default(0) @map("received_quantity") @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product          Product?      @relation(fields: [productId], references: [id])
  assets           Asset[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_lines")
}

model GoodsReceipt {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId String   @map("purchase_order_id") @db.Uuid
  receivedById    String?  @map("received_by_id") @db.Uuid
  receivedAt      DateTime @default(now()) @map("received_at")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receivedBy      User?         @relation("GoodsReceiptReceivedBy", fields: [receivedById], references: [id])

  @@index([purchaseOrderId])
  @@index([receivedById])
  @@map("goods_receipts")
}

model SupplierInvoice {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId String                @map("purchase_order_id") @db.Uuid
  invoiceNumber   String                @map("invoice_number")
  invoiceDate     DateTime              @map("invoice_date") @db.Date
  dueDate         DateTime?             @map("due_date") @db.Date
  amount          Decimal               @db.Decimal(12, 2)
  status          SupplierInvoiceStatus @default(received)
  documentId      String?               @map("document_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  deletedAt       DateTime?             @map("deleted_at")

  purchaseOrder   PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  document        Document?             @relation(fields: [documentId], references: [id])

  @@index([purchaseOrderId])
  @@index([status])
  @@index([documentId])
  @@index([deletedAt])
  @@map("supplier_invoices")
}

model CustomerInvoice {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber     String                @unique @map("invoice_number")
  accountId         String                @map("account_id") @db.Uuid
  projectId         String?               @map("project_id") @db.Uuid
  quoteId           String?               @map("quote_id") @db.Uuid
  status            CustomerInvoiceStatus @default(draft)
  issueDate         DateTime?             @map("issue_date") @db.Date
  dueDate           DateTime?             @map("due_date") @db.Date
  amount            Decimal               @default(0) @db.Decimal(12, 2)
  vatAmount         Decimal               @default(0) @map("vat_amount") @db.Decimal(12, 2)
  totalAmount       Decimal               @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount        Decimal               @default(0) @map("paid_amount") @db.Decimal(12, 2)
  outstandingAmount Decimal               @default(0) @map("outstanding_amount") @db.Decimal(12, 2)
  currency          String                @default("GBP")
  notes             String?
  createdById       String?               @map("created_by_id") @db.Uuid
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  deletedAt         DateTime?             @map("deleted_at")

  account           Account               @relation(fields: [accountId], references: [id])
  project           Project?              @relation(fields: [projectId], references: [id])
  quote             Quote?                @relation(fields: [quoteId], references: [id])
  createdBy         User?                 @relation("CustomerInvoiceCreatedBy", fields: [createdById], references: [id])
  payments          CustomerPayment[]
  billingSchedules  BillingSchedule[]

  @@index([accountId])
  @@index([projectId])
  @@index([quoteId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("customer_invoices")
}

model CustomerPayment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  paymentDate DateTime @map("payment_date") @db.Date
  amount      Decimal  @db.Decimal(12, 2)
  method      String?
  reference   String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invoice      CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([paymentDate])
  @@map("customer_payments")
}

model BillingSchedule {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String                @map("project_id") @db.Uuid
  description     String
  trigger         BillingScheduleTrigger
  percentage      Decimal?              @db.Decimal(7, 2)
  amount          Decimal               @default(0) @db.Decimal(12, 2)
  dueDate         DateTime?             @map("due_date") @db.Date
  status          BillingScheduleStatus @default(pending)
  linkedInvoiceId String?               @map("linked_invoice_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linkedInvoice   CustomerInvoice?      @relation(fields: [linkedInvoiceId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([linkedInvoiceId])
  @@map("billing_schedules")
}

model Asset {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetNumber         String      @unique @map("asset_number")
  projectId           String?     @map("project_id") @db.Uuid
  accountId           String?     @map("account_id") @db.Uuid
  purchaseOrderLineId String?     @map("purchase_order_line_id") @db.Uuid
  productId           String?     @map("product_id") @db.Uuid
  sku                 String?
  manufacturer        String?
  model               String?
  serialNumber        String?     @map("serial_number")
  macAddress          String?     @map("mac_address")
  description         String
  status              AssetStatus @default(required)
  location            String?
  warrantyStart       DateTime?   @map("warranty_start") @db.Date
  warrantyEnd         DateTime?   @map("warranty_end") @db.Date
  notes               String?
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  deletedAt           DateTime?   @map("deleted_at")

  project             Project?           @relation(fields: [projectId], references: [id])
  account             Account?           @relation(fields: [accountId], references: [id])
  purchaseOrderLine   PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id])
  product             Product?           @relation(fields: [productId], references: [id])
  helpdeskTickets     HelpdeskTicket[]

  @@index([projectId])
  @@index([accountId])
  @@index([purchaseOrderLineId])
  @@index([productId])
  @@index([status])
  @@index([serialNumber])
  @@index([macAddress])
  @@index([deletedAt])
  @@map("assets")
}

model HelpdeskQueue {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tickets     HelpdeskTicket[]

  @@index([active])
  @@map("helpdesk_queues")
}

model HelpdeskSlaPolicy {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  priority          HelpdeskPriority
  responseMinutes   Int               @map("response_minutes")
  resolutionMinutes Int               @map("resolution_minutes")
  businessHoursOnly Boolean           @default(true) @map("business_hours_only")
  active            Boolean           @default(true)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@unique([name, priority])
  @@index([priority])
  @@index([active])
  @@map("helpdesk_sla_policies")
}

model HelpdeskTicket {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketNumber       String               @unique @map("ticket_number")
  accountId          String?              @map("account_id") @db.Uuid
  contactId          String?              @map("contact_id") @db.Uuid
  projectId          String?              @map("project_id") @db.Uuid
  assetId            String?              @map("asset_id") @db.Uuid
  raisedByUserId     String?              @map("raised_by_user_id") @db.Uuid
  raisedByName       String?              @map("raised_by_name")
  raisedByEmail      String?              @map("raised_by_email")
  title              String
  description        String
  ticketType         HelpdeskTicketType   @map("ticket_type")
  category           HelpdeskTicketCategory
  priority           HelpdeskPriority     @default(normal)
  impact             HelpdeskImpact       @default(low)
  urgency            HelpdeskUrgency      @default(low)
  status             HelpdeskTicketStatus @default(new)
  slaStatus          HelpdeskSlaStatus    @default(on_track) @map("sla_status")
  assignedToId       String?              @map("assigned_to_id") @db.Uuid
  queueId            String?              @map("queue_id") @db.Uuid
  slaResponseDueAt   DateTime?            @map("sla_response_due_at")
  slaResolutionDueAt DateTime?            @map("sla_resolution_due_at")
  firstResponseAt    DateTime?            @map("first_response_at")
  resolvedAt         DateTime?            @map("resolved_at")
  closedAt           DateTime?            @map("closed_at")
  source             HelpdeskTicketSource @default(manual)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  deletedAt          DateTime?            @map("deleted_at")

  account            Account?             @relation(fields: [accountId], references: [id])
  contact            Contact?             @relation(fields: [contactId], references: [id])
  project            Project?             @relation(fields: [projectId], references: [id])
  asset              Asset?               @relation(fields: [assetId], references: [id])
  raisedByUser       User?                @relation("HelpdeskTicketRaisedByUser", fields: [raisedByUserId], references: [id])
  assignedTo         User?                @relation("HelpdeskTicketAssignedTo", fields: [assignedToId], references: [id])
  queue              HelpdeskQueue?       @relation(fields: [queueId], references: [id])
  comments           HelpdeskTicketComment[]
  resourceBookings   ResourceBooking[]

  @@index([accountId])
  @@index([contactId])
  @@index([projectId])
  @@index([assetId])
  @@index([raisedByUserId])
  @@index([assignedToId])
  @@index([queueId])
  @@index([priority])
  @@index([status])
  @@index([slaStatus])
  @@index([slaResponseDueAt])
  @@index([slaResolutionDueAt])
  @@index([deletedAt])
  @@map("helpdesk_tickets")
}

model HelpdeskTicketComment {
  id         String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId   String                    @map("ticket_id") @db.Uuid
  authorId   String?                   @map("author_id") @db.Uuid
  visibility HelpdeskCommentVisibility @default(internal)
  body       String
  createdAt  DateTime                  @default(now()) @map("created_at")
  updatedAt  DateTime                  @updatedAt @map("updated_at")
  deletedAt  DateTime?                 @map("deleted_at")

  ticket     HelpdeskTicket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User?                     @relation("HelpdeskTicketCommentAuthor", fields: [authorId], references: [id])

  @@index([ticketId])
  @@index([authorId])
  @@index([visibility])
  @@index([deletedAt])
  @@map("helpdesk_ticket_comments")
}

model KnowledgeArticle {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  category    String?
  body        String
  status      KnowledgeArticleStatus @default(draft)
  createdById String?                @map("created_by_id") @db.Uuid
  updatedById String?                @map("updated_by_id") @db.Uuid
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  createdBy   User?                  @relation("KnowledgeArticleCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?                  @relation("KnowledgeArticleUpdatedBy", fields: [updatedById], references: [id])

  @@index([status])
  @@index([category])
  @@map("knowledge_articles")
}
