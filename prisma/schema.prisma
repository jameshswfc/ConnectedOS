  rejectedBy        User?              @relation("ExpenseClaimRejectedBy", fields: [rejectedById], references: [id])
  paidBy            User?              @relation("ExpenseClaimPaidBy", fields: [paidById], references: [id])
  lines             ExpenseLine[]

  @@index([userId])
  @@index([projectId])
  @@index([resourceBookingId])
  @@index([accountId])
  @@index([status])
  @@index([submittedAt])
  @@index([deletedAt])
  @@map("expense_claims")
