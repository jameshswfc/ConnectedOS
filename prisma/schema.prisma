model Resource {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceType    ResourceType @map("resource_type")
  userId          String?      @unique @map("user_id") @db.Uuid
  displayName     String       @map("display_name")
  companyName     String?      @map("company_name")
  roleType        String?      @map("role_type")
  skillTags       String[]     @default([]) @map("skill_tags")
  phone           String?
  email           String?
  address         String?
  agentName       String?      @map("agent_name")
  agentPhone      String?      @map("agent_phone")
  agentEmail      String?      @map("agent_email")
  standardDayCost Decimal      @default(0) @map("standard_day_cost") @db.Decimal(12, 2)
  standardDaySell Decimal      @default(0) @map("standard_day_sell") @db.Decimal(12, 2)
  halfDayCost     Decimal      @default(0) @map("half_day_cost") @db.Decimal(12, 2)
  halfDaySell     Decimal      @default(0) @map("half_day_sell") @db.Decimal(12, 2)
  hourlyCost      Decimal      @default(0) @map("hourly_cost") @db.Decimal(12, 2)
  hourlySell      Decimal      @default(0) @map("hourly_sell") @db.Decimal(12, 2)
  notes           String?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  user            User?        @relation("ResourceUser", fields: [userId], references: [id])
  bookings        ResourceBooking[]
  projectAssignments ProjectResourceAssignment[]

  @@index([resourceType])
  @@index([active])
  @@index([displayName])
  @@index([deletedAt])
  @@map("resources")
}

model ResourceBooking {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resourceId       String                @map("resource_id") @db.Uuid
  projectId        String?               @map("project_id") @db.Uuid
  accountId        String?               @map("account_id") @db.Uuid
  opportunityId    String?               @map("opportunity_id") @db.Uuid
  helpdeskTicketId String?               @map("helpdesk_ticket_id") @db.Uuid
  bookingType      ResourceBookingType   @map("booking_type")
  title            String
  description      String?
  location         String?
  startDate        DateTime              @map("start_date") @db.Date
  endDate          DateTime              @map("end_date") @db.Date
  startTime        DateTime?             @map("start_time")
  endTime          DateTime?             @map("end_time")
  workingDays      Decimal               @default(0) @map("working_days") @db.Decimal(8, 2)
  costRate         Decimal               @default(0) @map("cost_rate") @db.Decimal(12, 2)
  sellRate         Decimal               @default(0) @map("sell_rate") @db.Decimal(12, 2)
  costTotal        Decimal               @default(0) @map("cost_total") @db.Decimal(12, 2)
  sellTotal        Decimal               @default(0) @map("sell_total") @db.Decimal(12, 2)
  chargeable       Boolean               @default(true)
  status           ResourceBookingStatus @default(draft)
  conflictStatus   BookingConflictStatus @default(clear) @map("conflict_status")
  overrideReason   String?               @map("override_reason")
  createdById      String?               @map("created_by_id") @db.Uuid
  approvedById     String?               @map("approved_by_id") @db.Uuid
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  deletedAt        DateTime?             @map("deleted_at")

  resource         Resource              @relation(fields: [resourceId], references: [id])
  project          Project?              @relation(fields: [projectId], references: [id])
  account          Account?              @relation(fields: [accountId], references: [id])
  opportunity      Opportunity?          @relation(fields: [opportunityId], references: [id])
  helpdeskTicket   HelpdeskTicket?       @relation(fields: [helpdeskTicketId], references: [id])
  createdBy        User?                 @relation("ResourceBookingCreatedBy", fields: [createdById], references: [id])
  approvedBy       User?                 @relation("ResourceBookingApprovedBy", fields: [approvedById], references: [id])
  expenseClaims    ExpenseClaim[]
  expenseLines     ExpenseLine[]

  @@index([resourceId])
  @@index([projectId])
  @@index([accountId])
  @@index([opportunityId])
  @@index([helpdeskTicketId])
  @@index([bookingType])
  @@index([status])
  @@index([conflictStatus])
  @@index([startDate])
  @@index([endDate])
  @@index([deletedAt])
  @@map("resource_bookings")
}

