model ProjectMilestone {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String                 @map("project_id") @db.Uuid
  title         String
  description   String?
  milestoneDate DateTime               @map("milestone_date") @db.Date
  baselineDate  DateTime?              @map("baseline_date") @db.Date
  manualDateOverride Boolean           @default(false) @map("manual_date_override")
  status        ProjectMilestoneStatus @default(not_started)
  ownerId       String?                @map("owner_id") @db.Uuid
  completedAt   DateTime?              @map("completed_at")
  sortOrder     Int                    @default(0) @map("sort_order")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  deletedAt     DateTime?              @map("deleted_at")

  project       Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner         User?                  @relation("ProjectMilestoneOwner", fields: [ownerId], references: [id])

  @@unique([projectId, title])
  @@index([projectId])
  @@index([ownerId])
  @@index([status])
  @@index([milestoneDate])
  @@index([deletedAt])
  @@map("project_milestones")
}

model ProjectStageGate {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String               @map("project_id") @db.Uuid
  stage         ProjectDeliveryStage
  status        StageGateStatus      @default(not_started)
  completedAt   DateTime?            @map("completed_at")
  completedById String?              @map("completed_by_id") @db.Uuid
  notes         String?
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  completedBy   User?                @relation("ProjectStageGateCompletedBy", fields: [completedById], references: [id])

  @@unique([projectId, stage])
  @@index([projectId])
  @@index([stage])
  @@index([status])
  @@index([completedById])
  @@map("project_stage_gates")
}

model ProjectTask {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String            @map("project_id") @db.Uuid
  title         String
  description   String?
  status        ProjectTaskStatus @default(not_started)
  ownerId       String?           @map("owner_id") @db.Uuid
  assignedToId  String?           @map("assigned_to_id") @db.Uuid
  startDate     DateTime          @map("start_date") @db.Date
  endDate       DateTime          @map("end_date") @db.Date
  baselineStartDate DateTime?     @map("baseline_start_date") @db.Date
  baselineEndDate   DateTime?     @map("baseline_end_date") @db.Date
  estimatedDays Decimal           @default(0) @map("estimated_days") @db.Decimal(8, 2)
  baselineEstimatedDays Decimal?  @map("baseline_estimated_days") @db.Decimal(8, 2)
  actualDays    Decimal           @default(0) @map("actual_days") @db.Decimal(8, 2)
  sortOrder     Int               @default(0) @map("sort_order")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  deletedAt     DateTime?         @map("deleted_at")

  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner         User?             @relation("ProjectTaskOwner", fields: [ownerId], references: [id])
  assignedTo    User?             @relation("ProjectTaskAssignedTo", fields: [assignedToId], references: [id])
  predecessors  ProjectTaskDependency[] @relation("ProjectTaskPredecessor")
  successors    ProjectTaskDependency[] @relation("ProjectTaskSuccessor")

  @@index([projectId])
  @@index([ownerId])
  @@index([assignedToId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([baselineEndDate])
  @@index([deletedAt])
  @@map("project_tasks")
}

model ProjectTaskDependency {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String                @map("project_id") @db.Uuid
  predecessorTaskId String                @map("predecessor_task_id") @db.Uuid
  successorTaskId   String                @map("successor_task_id") @db.Uuid
  dependencyType    ProjectDependencyType @default(finish_to_start) @map("dependency_type")
  lagDays           Int                   @default(0) @map("lag_days")
  createdAt         DateTime              @default(now()) @map("created_at")

  project           Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  predecessorTask   ProjectTask           @relation("ProjectTaskPredecessor", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  successorTask     ProjectTask           @relation("ProjectTaskSuccessor", fields: [successorTaskId], references: [id], onDelete: Cascade)

  @@unique([predecessorTaskId, successorTaskId])
  @@index([projectId])
  @@index([predecessorTaskId])
  @@index([successorTaskId])
  @@map("project_task_dependencies")
}

model ProjectResourceAssignment {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String              @map("project_id") @db.Uuid
  resourceId    String?             @map("resource_id") @db.Uuid
  userId        String?             @map("user_id") @db.Uuid
  role          ProjectResourceRole @default(project_engineer)
  startDate     DateTime            @map("start_date") @db.Date
  endDate       DateTime            @map("end_date") @db.Date
