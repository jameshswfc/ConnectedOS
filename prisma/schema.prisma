model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  microsoftId   String?  @unique @map("microsoft_id")
  displayName   String   @map("display_name")
  email         String   @unique
  passwordHash  String?  @map("password_hash")
  jobTitle      String?  @map("job_title")
  department    String?
  roleId        String   @map("role_id") @db.Uuid
  permissionLevel PermissionLevel @default(user) @map("permission_level")
  isActive      Boolean  @default(true) @map("is_active")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  lastLoginAt   DateTime? @map("last_login_at")
  userType      UserType @default(internal) @map("user_type")
  createdAt     DateTime @default(now()) @map("created_at")
  createdById   String?  @map("created_by_id") @db.Uuid
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedById   String?  @map("updated_by_id") @db.Uuid
  deactivatedAt DateTime? @map("deactivated_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?  @map("deleted_by_id") @db.Uuid

  role          Role     @relation(fields: [roleId], references: [id])
  auditLogs     AuditLog[]
  notifications Notification[]
  comments      Comment[]
  ownedAccounts Account[] @relation("AccountOwner")
  createdAccounts Account[] @relation("AccountCreatedBy")
  updatedAccounts Account[] @relation("AccountUpdatedBy")
  deletedAccounts Account[] @relation("AccountDeletedBy")
  ownedLeads Lead[] @relation("LeadOwner")
  ownedOpportunities Opportunity[] @relation("OpportunityOwner")
  ownedSalesActivities SalesActivity[] @relation("SalesActivityOwner")
  ownedQuotes Quote[] @relation("QuoteOwner")
  uploadedPriceImports PriceImport[] @relation("PriceImportUploadedBy")
  requestedQuoteApprovals QuoteApprovalRequest[] @relation("QuoteApprovalRequestedBy")
  assignedQuoteApprovals QuoteApprovalRequest[] @relation("QuoteApprovalApprover")
  generatedQuoteExports QuoteExport[] @relation("QuoteExportGeneratedBy")
  requestedPresalesRequests PresalesRequest[] @relation("PresalesRequestRequestedBy")
  assignedPresalesRequests PresalesRequest[] @relation("PresalesRequestAssignedTo")
  assignedPresalesTasks PresalesTask[] @relation("PresalesTaskAssignedTo")
  uploadedPresalesDeliverables PresalesDeliverable[] @relation("PresalesDeliverableUploadedBy")
  assignedPresalesDeliverables PresalesDeliverable[] @relation("PresalesDeliverableAssignedTo")
  managedProjects Project[] @relation("ProjectManager")
  createdProjects Project[] @relation("ProjectCreatedBy")
  updatedProjects Project[] @relation("ProjectUpdatedBy")
  deletedProjects Project[] @relation("ProjectDeletedBy")
  planBaselinedProjects Project[] @relation("ProjectPlanBaselinedBy")
  ownedProjectTasks ProjectTask[] @relation("ProjectTaskOwner")
  assignedProjectTasks ProjectTask[] @relation("ProjectTaskAssignedTo")
  ownedProjectMilestones ProjectMilestone[] @relation("ProjectMilestoneOwner")
  completedProjectStageGates ProjectStageGate[] @relation("ProjectStageGateCompletedBy")
  projectResourceAssignments ProjectResourceAssignment[]
  ownedProjectActivities ProjectActivity[] @relation("ProjectActivityOwner")
  assignedProjectActivities ProjectActivity[] @relation("ProjectActivityAssignedTo")
  ownedProjectIssueActions ProjectIssueAction[] @relation("ProjectIssueActionOwner")
  preparedProjectForms ProjectForm[] @relation("ProjectFormPreparedBy")
  resourceProfile Resource? @relation("ResourceUser")
  createdResourceBookings ResourceBooking[] @relation("ResourceBookingCreatedBy")
  approvedResourceBookings ResourceBooking[] @relation("ResourceBookingApprovedBy")
  leaveRequests LeaveRequest[] @relation("LeaveRequestUser")
  leaveApprovals LeaveRequest[] @relation("LeaveRequestApprover")
  expenseClaims ExpenseClaim[] @relation("ExpenseClaimUser")
  approvedExpenseClaims ExpenseClaim[] @relation("ExpenseClaimApprovedBy")
  rejectedExpenseClaims ExpenseClaim[] @relation("ExpenseClaimRejectedBy")
  expenseClaimsPaid ExpenseClaim[] @relation("ExpenseClaimPaidBy")
  purchaseOrdersRequested PurchaseOrder[] @relation("PurchaseOrderRequestedBy")
  purchaseOrdersApproved PurchaseOrder[] @relation("PurchaseOrderApprovedBy")
  goodsReceiptsReceived GoodsReceipt[] @relation("GoodsReceiptReceivedBy")
  createdCustomerInvoices CustomerInvoice[] @relation("CustomerInvoiceCreatedBy")
  assignedHelpdeskTickets HelpdeskTicket[] @relation("HelpdeskTicketAssignedTo")
  raisedHelpdeskTickets HelpdeskTicket[] @relation("HelpdeskTicketRaisedByUser")
  helpdeskComments HelpdeskTicketComment[] @relation("HelpdeskTicketCommentAuthor")
  createdKnowledgeArticles KnowledgeArticle[] @relation("KnowledgeArticleCreatedBy")
  updatedKnowledgeArticles KnowledgeArticle[] @relation("KnowledgeArticleUpdatedBy")

  @@index([roleId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @unique
  description     String?
  isSystemRole    Boolean  @default(true) @map("is_system_role")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String   @unique
  description     String?
  module          String
  action          String
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp     DateTime @default(now())
  userId        String?  @map("user_id") @db.Uuid
  module        String
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id")
  action        String
  previousValue Json?    @map("previous_value")
  newValue      Json?    @map("new_value")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")

  user          User?    @relation(fields: [userId], references: [id])

  @@index([module])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([userId])
  @@map("audit_logs")
}

model Notification {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String             @map("user_id") @db.Uuid
  title        String
  body         String
  status       NotificationStatus @default(unread)
  metadata     Json?
  createdAt    DateTime           @default(now()) @map("created_at")
  readAt       DateTime?          @map("read_at")
  archivedAt   DateTime?          @map("archived_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
  @@map("notifications")
}

model Document {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storageProvider DocumentStorageProvider @default(sharepoint) @map("storage_provider")
  externalId      String?                 @map("external_id")
  webUrl          String?                 @map("web_url")
  folderPath      String?                 @map("folder_path")
  storagePath     String?                 @map("storage_path")
  versionLabel    String?                 @map("version_label")
  fileName        String                  @map("file_name")
  fileType        String?                 @map("file_type")
  sizeBytes       Int?                    @map("size_bytes")
  entityType      String?                 @map("entity_type")
  entityId        String?                 @map("entity_id")
  uploadedById    String?                 @map("uploaded_by_id") @db.Uuid
  uploadedAt      DateTime                @default(now()) @map("uploaded_at")
  deletedAt       DateTime?               @map("deleted_at")
  deletedById     String?                 @map("deleted_by_id") @db.Uuid
  presalesDeliverables PresalesDeliverable[]
  projectDocumentRecords ProjectDocumentRecord[]
  expenseLines ExpenseLine[]
  supplierInvoices SupplierInvoice[]

  @@index([entityType, entityId])
  @@index([uploadedById])
  @@index([deletedAt])
  @@map("documents")
}

model Comment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  body        String
  isInternal  Boolean  @default(true) @map("is_internal")
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by_id") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id") @db.Uuid
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?  @map("deleted_by_id") @db.Uuid

  createdBy   User?    @relation(fields: [createdById], references: [id])

  @@index([entityType, entityId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("comments")
}

model Account {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  accountType   AccountType   @default(prospect) @map("account_type")
  status        AccountStatus @default(prospect)
  website       String?
  phone         String?
  addressLine1  String?       @map("address_line_1")
  addressLine2  String?       @map("address_line_2")
  city          String?
  county        String?
  postcode      String?
  country       String?
  industry      String?
  ownerId       String        @map("owner_id") @db.Uuid
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  createdById   String?       @map("created_by_id") @db.Uuid
  updatedAt     DateTime      @updatedAt @map("updated_at")
  updatedById   String?       @map("updated_by_id") @db.Uuid
  deletedAt     DateTime?     @map("deleted_at")
  deletedById   String?       @map("deleted_by_id") @db.Uuid

  owner         User          @relation("AccountOwner", fields: [ownerId], references: [id])
  createdBy     User?         @relation("AccountCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?         @relation("AccountUpdatedBy", fields: [updatedById], references: [id])
  deletedBy     User?         @relation("AccountDeletedBy", fields: [deletedById], references: [id])
  contacts      Contact[]
  leads         Lead[]
  opportunities Opportunity[]
  salesActivities SalesActivity[]
  quotes        Quote[]
  presalesRequests PresalesRequest[]
  projects      Project[]
  resourceBookings ResourceBooking[]
  expenseClaims ExpenseClaim[]
  suppliers     Supplier[]
  customerInvoices CustomerInvoice[]
  assets        Asset[]
  helpdeskTickets HelpdeskTicket[]

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("accounts")
}

model Contact {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId            String        @map("account_id") @db.Uuid
  firstName            String        @map("first_name")
  lastName             String        @map("last_name")
  jobTitle             String?       @map("job_title")
  email                String?
  phone                String?
  mobile               String?
  linkedinUrl          String?       @map("linkedin_url")
  isPrimary            Boolean       @default(false) @map("is_primary")
  relationshipStrength RelationshipStrength @default(unknown) @map("relationship_strength")
  notes                String?
  status               ContactStatus @default(active)
  createdAt            DateTime      @default(now()) @map("created_at")
  createdById          String?       @map("created_by_id") @db.Uuid
  updatedAt            DateTime      @updatedAt @map("updated_at")
  updatedById          String?       @map("updated_by_id") @db.Uuid
  deletedAt            DateTime?     @map("deleted_at")
  deletedById          String?       @map("deleted_by_id") @db.Uuid

  account              Account       @relation(fields: [accountId], references: [id])
  primaryForOpportunities Opportunity[] @relation("OpportunityPrimaryContact")
  salesActivities      SalesActivity[]
  leads                Lead[]
  quotes               Quote[]
  helpdeskTickets      HelpdeskTicket[]

  @@index([accountId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@map("contacts")
}

model Lead {
  id                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId              String?    @map("account_id") @db.Uuid
  contactId              String?    @map("contact_id") @db.Uuid
  accountName            String?    @map("account_name")
  contactName            String?    @map("contact_name")
  email                  String?
  phone                  String?
  source                 String?
  status                 LeadStatus @default(new)
  estimatedValue         Decimal?   @map("estimated_value") @db.Decimal(12, 2)
  ownerId                String     @map("owner_id") @db.Uuid
  nextActionDate         DateTime?  @map("next_action_date") @db.Date
  convertedAccountId     String?    @map("converted_account_id") @db.Uuid
  convertedContactId     String?    @map("converted_contact_id") @db.Uuid
  convertedOpportunityId String?    @map("converted_opportunity_id") @db.Uuid
  createdAt              DateTime   @default(now()) @map("created_at")
  createdById            String?    @map("created_by_id") @db.Uuid
  updatedAt              DateTime   @updatedAt @map("updated_at")
  updatedById            String?    @map("updated_by_id") @db.Uuid
  deletedAt              DateTime?  @map("deleted_at")
  deletedById            String?    @map("deleted_by_id") @db.Uuid

  account                Account?   @relation(fields: [accountId], references: [id])
  contact                Contact?   @relation(fields: [contactId], references: [id])
  owner                  User       @relation("LeadOwner", fields: [ownerId], references: [id])
  salesActivities        SalesActivity[]

  @@index([accountId])
  @@index([contactId])
  @@index([ownerId])
  @@index([status])
  @@index([nextActionDate])
  @@index([deletedAt])
  @@map("leads")
}

model Opportunity {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId          String            @map("account_id") @db.Uuid
  primaryContactId   String?           @map("primary_contact_id") @db.Uuid
  ownerId            String            @map("owner_id") @db.Uuid
  opportunityName    String            @map("opportunity_name")
  opportunityType    OpportunityType   @default(other) @map("opportunity_type")
  stage              OpportunityStage  @default(lead)
  status             OpportunityStatus @default(open)
  value              Decimal           @default(0) @db.Decimal(12, 2)
  marginPercent      Decimal?          @map("margin_percent") @db.Decimal(5, 2)
  probabilityPercent Int               @default(0) @map("probability_percent")
  weightedValue      Decimal           @default(0) @map("weighted_value") @db.Decimal(12, 2)
  expectedCloseDate  DateTime?         @map("expected_close_date") @db.Date
  source             OpportunitySource? @default(other)
  competitor         String?
  nextActionDate     DateTime?         @map("next_action_date") @db.Date
  lastActivityAt     DateTime?         @map("last_activity_at")
  wonDate            DateTime?         @map("won_date") @db.Date
  lostDate           DateTime?         @map("lost_date") @db.Date
  lostReason         String?           @map("lost_reason")
  notes              String?
  createdAt          DateTime          @default(now()) @map("created_at")
  createdById        String?           @map("created_by_id") @db.Uuid
  updatedAt          DateTime          @updatedAt @map("updated_at")
  updatedById        String?           @map("updated_by_id") @db.Uuid
  deletedAt          DateTime?         @map("deleted_at")
  deletedById        String?           @map("deleted_by_id") @db.Uuid

