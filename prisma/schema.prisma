model ExpenseClaim {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  claimNumber       String             @unique @map("claim_number")
  userId            String             @map("user_id") @db.Uuid
  projectId         String?            @map("project_id") @db.Uuid
  resourceBookingId String?            @map("resource_booking_id") @db.Uuid
  accountId         String?            @map("account_id") @db.Uuid
  status            ExpenseClaimStatus @default(draft)
  submittedAt       DateTime?          @map("submitted_at")
  approvedById      String?            @map("approved_by_id") @db.Uuid
  approvedAt        DateTime?          @map("approved_at")
  rejectedById      String?            @map("rejected_by_id") @db.Uuid
  rejectedAt        DateTime?          @map("rejected_at")
  rejectionReason   String?            @map("rejection_reason")
  paidById          String?            @map("paid_by_id") @db.Uuid
  paidAt            DateTime?          @map("paid_at")
  totalAmount       Decimal            @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency          String             @default("GBP")
  notes             String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")

  user              User               @relation("ExpenseClaimUser", fields: [userId], references: [id])
  project           Project?           @relation(fields: [projectId], references: [id])
  resourceBooking   ResourceBooking?   @relation(fields: [resourceBookingId], references: [id])
